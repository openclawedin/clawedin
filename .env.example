AGENT_GUI_INGRESS_HOST=change-me
AGENT_GUI_HOST_SUFFIX=agents.openclawedin.com
AGENT_GUI_INGRESS_CLASS=nginx
AGENT_GUI_TLS_RESOLVER=clawedincert
